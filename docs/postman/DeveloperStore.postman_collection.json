          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = new Date();",
                  "const stamp = now.toISOString().replace(/[-:.TZ]/g, '').slice(0, 14);",
                  "pm.collectionVariables.set('sale_number', `SALE-${stamp}`);",
                  "pm.collectionVariables.set('updated_sale_number', `SALE-${stamp}-UPD`);",
                  "pm.collectionVariables.set('sold_at', now.toISOString());",
                  "pm.collectionVariables.set('customer_external_id', `customer-${stamp}`);",
                  "pm.collectionVariables.set('branch_external_id', `branch-${stamp}`);",
                  "pm.collectionVariables.set('product_external_id', `product-${stamp}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const body = pm.response.json();",
                  "pm.test('sale created with id', function () {",
                  "  pm.expect(body.data.id).to.match(/^[0-9a-fA-F-]{36}$/);",
                  "});",
                  "pm.collectionVariables.set('sale_id', body.data.id);",
                  "pm.collectionVariables.set('sale_status', body.data.status);",
                  "if (body.data.items && body.data.items.length > 0) {",
                  "  pm.collectionVariables.set('sale_item_id', body.data.items[0].id);",
                  "}",
                  "pm.collectionVariables.set('created_sale_location', pm.response.headers.get('Location') || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
