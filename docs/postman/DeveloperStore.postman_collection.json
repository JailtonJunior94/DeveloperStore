  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = new Date();",
          "const stamp = now.toISOString().replace(/[-:.TZ]/g, '').slice(0, 14);",
          "const defaults = {",
          "  api_version: 'v1',",
          "  base_url: pm.environment.get('base_url') || 'http://localhost:5119',",
          "  token: pm.environment.get('token') || '',",
          "  sale_number: `SALE-${stamp}` ,",
          "  updated_sale_number: `SALE-${stamp}-UPD`,",
          "  sold_at: now.toISOString(),",
          "  customer_external_id: `customer-${stamp}`,",
          "  customer_name: 'Jane Doe',",
          "  branch_external_id: `branch-${stamp}`,",
          "  branch_name: 'Central',",
          "  product_external_id: `product-${stamp}`,",
          "  product_name: 'Notebook Pro 14',",
          "  product_quantity: '4',",
          "  product_unit_price: '10.00',",
          "  updated_product_quantity: '10',",
          "  list_page: '1',",
          "  list_size: '10',",
          "  list_order: 'soldAt desc, saleNumber asc',",
          "  list_status: 'NotCancelled'",
          "};",
          "Object.entries(defaults).forEach(([key, value]) => {",
          "  if (!pm.collectionVariables.get(key)) {",
          "    pm.collectionVariables.set(key, value);",
          "  }",
          "});"
        ]
      }
    }
  ],
